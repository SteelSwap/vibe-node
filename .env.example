# vibe-node development environment configuration
# Copy to .env and customize as needed: cp .env.example .env

# ─── Network ──────────────────────────────────────────────────────
# Cardano network: preprod or mainnet
CARDANO_NETWORK=preprod

# ─── ParadeDB ─────────────────────────────────────────────────────
POSTGRES_USER=vibenode
POSTGRES_PASSWORD=vibenode
POSTGRES_DB=vibenode
PARADEDB_PORT=5432

# ─── Ollama Embedding Server ─────────────────────────────────────
# Embedding model pulled on first startup
EMBEDDING_MODEL=unclemusclez/jina-embeddings-v2-base-code
OLLAMA_PORT=11434

# ─── Mithril ─────────────────────────────────────────────────────
# Snapshot digest: "latest" or a specific digest hash
SNAPSHOT_DIGEST=latest
# Aggregator endpoint (preprod default, change for mainnet)
AGGREGATOR_ENDPOINT=https://aggregator.release-preprod.api.mithril.network/aggregator
# Genesis verification key (preprod default)
# For mainnet, use: https://raw.githubusercontent.com/input-output-hk/mithril/main/mithril-infra/configuration/release-mainnet/genesis.vkey
GENESIS_VERIFICATION_KEY=5b3132372c37332c3132342c3136312c362c3133372c3133312c3231332c3230372c3131372c3139382c38352c3137362c3139392c3136322c3234312c36382c3132332c3131392c3134352c31332c3233322c3234332c34392c3232392c322c3234392c3230352c3230352c33392c3233352c34345d

# ─── Cardano Node ────────────────────────────────────────────────
CARDANO_NODE_PORT=3001

# ─── Ogmios ──────────────────────────────────────────────────────
OGMIOS_PORT=1337
