# vibe-node development environment configuration
# Copy to .env and customize as needed: cp .env.example .env

# ─── GitHub API ──────────────────────────────────────────────────
# Required for ingesting issues and PRs from Cardano repos.
# Without a token: 60 requests/hour (too slow for ingestion).
# With a token: 5,000 requests/hour.
# Create one at: https://github.com/settings/tokens
# No special scopes needed — public repo access is sufficient.
GITHUB_TOKEN=

# ─── LLM API (for PydanticAI pipeline) ─────────────────────────
# Used by: vibe-node research extract-rules --subsystem X
#
# Option A: AWS Bedrock with bearer token (simplest)
AWS_BEARER_TOKEN=
AWS_DEFAULT_REGION=us-east-1
#
# Option B: AWS Bedrock with access keys
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
#
# Option B: Anthropic API (direct)
# Set ANTHROPIC_API_KEY and override models:
# ANTHROPIC_API_KEY=sk-ant-...
# EXTRACTION_MODEL=anthropic:claude-opus-4-20250514
# LINKING_MODEL=anthropic:claude-sonnet-4-20250514
#
# Model overrides (defaults use Bedrock):
# EXTRACTION_MODEL=bedrock:anthropic.claude-opus-4-6-v1
# LINKING_MODEL=bedrock:anthropic.claude-sonnet-4-6-v1

# ─── Network ──────────────────────────────────────────────────────
# Cardano network: preprod or mainnet
CARDANO_NETWORK=preprod

# ─── ParadeDB ─────────────────────────────────────────────────────
POSTGRES_USER=vibenode
POSTGRES_PASSWORD=vibenode
POSTGRES_DB=vibenode
PARADEDB_PORT=5432

# ─── PaddleOCR Service ───────────────────────────────────────────
# PDF-to-Mathpix-markdown conversion (runs in Docker with Python 3.13)
PADDLEOCR_PORT=8080
PADDLEOCR_URL=http://localhost:8080

# ─── Ollama Embedding Server ─────────────────────────────────────
# Embedding model pulled on first startup
# Official Jina Code Embeddings 1.5B from HuggingFace (1536-dim, Q8_0 quantization)
EMBEDDING_MODEL=hf.co/jinaai/jina-code-embeddings-1.5b-GGUF:Q8_0
OLLAMA_PORT=11434

# ─── Mithril ─────────────────────────────────────────────────────
# Snapshot digest: "latest" or a specific digest hash
SNAPSHOT_DIGEST=latest
# Aggregator endpoint (preprod default, change for mainnet)
AGGREGATOR_ENDPOINT=https://aggregator.release-preprod.api.mithril.network/aggregator
# Genesis verification key (preprod default)
# For mainnet, use: https://raw.githubusercontent.com/input-output-hk/mithril/main/mithril-infra/configuration/release-mainnet/genesis.vkey
GENESIS_VERIFICATION_KEY=5b3132372c37332c3132342c3136312c362c3133372c3133312c3231332c3230372c3131372c3139382c38352c3137362c3139392c3136322c3234312c36382c3132332c3131392c3134352c31332c3233322c3234332c34392c3232392c322c3234392c3230352c3230352c33392c3233352c34345d

# ─── Cardano Node ────────────────────────────────────────────────
CARDANO_NODE_PORT=3001

# ─── Ogmios ──────────────────────────────────────────────────────
OGMIOS_PORT=1337
